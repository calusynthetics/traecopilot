// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  casNumber   String?
  description String
  price       Float?
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String
  stockStatus String   // "IN_STOCK", "LOW_STOCK", "CONTACT"
  density     String?
  molarMass   String?
  flashPoint  String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Order {
  id              String   @id @default(cuid())
  customerName    String
  company         String?
  email           String
  phone           String
  deliveryAddress String
  items           Json     // List of items in the order
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}
